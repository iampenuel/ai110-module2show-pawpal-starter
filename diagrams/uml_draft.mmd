classDiagram
    %% PawPal+ DRAFT design (pre-implementation sketch).
    %% This is the initial plan. See uml_final.mmd for the diagram that matches the shipped code.

    class Owner {
        +str name
        +str contact
        +list~Pet~ pets
        +add_pet(pet)
        +get_pet(name) Pet
        +list_pets() list
        +get_all_tasks() list
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task)
        +list_tasks() list
        +get_task(task_id) Task
        +remove_task(task_id)
    }

    class Task {
        +str task_id
        +str description
        +datetime due_at
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +mark_complete()
        +create_next_occurrence() Task
        +end_time() datetime
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks() list
        +sort_by_due_time() list
        +filter_tasks() list
        +detect_conflicts() list
        +complete_task(task_id)
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : schedules for
